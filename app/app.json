{
  "expo": {
    "name": "Peakked",
    "slug": "peakked",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logos/Full Logo.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "splash": {
      "image": "./assets/Logos/Full Logo WO BG.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#000000"
    },
    "android": {
      "navigationBar": {
        "backgroundColor": "#000000"
      },
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/Logos/image logo WO BG.png",
        "backgroundImage": "./assets/Logos/Full Logo.png",
        "monochromeImage": "./assets/Logos/monochrome logo WO BG.png"
      }
    },
    "web": {
      "favicon": "./assets/Logos/Image logo.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sharing",
      "expo-image"
    ]
  }
}
