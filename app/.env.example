# Copy to `.env` and fill values for **live** API mode.
# Frontend demo (default): omit or set:
EXPO_PUBLIC_DEMO_MODE=true

# When EXPO_PUBLIC_DEMO_MODE=false, point the app at your FastAPI backend:
# EXPO_PUBLIC_API_URL=http://localhost:8000/api

# Backend keys (only needed when demo mode is off)
# OPENAI_API_KEY=
# RAWG_API_KEY=
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# STEAM_API_KEY=
# REDIS_URL=
