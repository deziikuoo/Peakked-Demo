# Copy to `.env` and fill values for **live** API mode.
# Frontend demo (default): omit or set:
EXPO_PUBLIC_DEMO_MODE=true

# Optional: Expo `expo start --tunnel` uses ngrok. If you see
# "Cannot read properties of undefined (reading 'body')", set a free token from
# https://dashboard.ngrok.com/get-started/your-authtoken then run once:
#   ngrok config add-authtoken <token>
# Or skip tunnel: `npm run android` (LAN) when phone and PC share Wi‑Fi.

# When EXPO_PUBLIC_DEMO_MODE=false, point the app at your FastAPI backend:
# EXPO_PUBLIC_API_URL=http://localhost:8000/api

# Physical device + `expo start --tunnel`: Expo’s host is *.exp.direct — not your API.
# Set your PC’s LAN IP (ipconfig / ifconfig) so the phone can reach :8000:
# EXPO_PUBLIC_LAN_API_HOST=192.168.1.123

# Backend keys (only needed when demo mode is off)
# OPENAI_API_KEY=
# RAWG_API_KEY=
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# STEAM_API_KEY=
# REDIS_URL=
